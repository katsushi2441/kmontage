[Unit]
Description=Kurage Montage API
After=network-online.target kurage-api.service

[Service]
Type=simple
WorkingDirectory=/home/kojima/work/kmontage
Environment=KURAGE_API=http://127.0.0.1:18303
Environment=OLLAMA_URL=http://192.168.0.3:11434
Environment=OLLAMA_MODEL=gemma4:12b-it-qat
# X動画の取得にログインCookieが必要な場合だけ有効化する。
# Environment=KMONTAGE_YTDLP_COOKIES_BROWSER=chrome
ExecStart=/usr/bin/python3 -m uvicorn backend.main:app --host 0.0.0.0 --port 18305
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
